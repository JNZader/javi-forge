# Local AI Stack — Environment Variables
# Copy to .env in your project: cp .env.example .env

# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434

# ── Open WebUI ──────────────────────────────────────────────────────────────
WEBUI_PORT=3000
WEBUI_AUTH=false

# ── n8n ─────────────────────────────────────────────────────────────────────
N8N_PORT=5678

# ── Supabase (Postgres) ────────────────────────────────────────────────────
SUPABASE_DB_PORT=5432
SUPABASE_DB_PASSWORD=postgres
SUPABASE_DB_NAME=app
