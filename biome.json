{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!!**/dist", "!!**/coverage", "!!**/reports", "!!**/node_modules"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useNodejsImportProtocol": "warn",
				"noNonNullAssertion": "warn"
			},
			"suspicious": {
				"noArrayIndexKey": "off",
				"noImplicitAnyLet": "error",
				"noTemplateCurlyInString": "warn"
			},
			"correctness": {
				"useExhaustiveDependencies": "off",
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn",
				"noUnusedFunctionParameters": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts", "**/*.test.tsx", "**/__tests__/**", "**/__integration__/**", "**/e2e/**"],
			"linter": {
				"rules": {
					"complexity": {
						"noBannedTypes": "off"
					},
					"style": {
						"noNonNullAssertion": "off",
						"useNodejsImportProtocol": "warn"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.tsx"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off"
					},
					"style": {
						"useImportType": "off"
					}
				}
			}
		},
		{
			"includes": ["src/lib/workflow/parser.ts", "src/lib/workflow/renderer.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		},
		{
			"includes": [
				"src/lib/atlassian-mcp.ts",
				"src/lib/docker.ts",
				"src/lib/__tests__/atlassian-mcp.test.ts",
				"src/lib/security-analysis.test.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noTemplateCurlyInString": "off"
					}
				}
			}
		}
	]
}
