# MkDocs configuration — generated by javi-forge template.docs.base
# Rename to mkdocs.yml and customize for your project.
#
# Run locally:
#   pip install mkdocs-material
#   mkdocs serve
#
# Build:
#   mkdocs build --strict
#
# Deploy to GitHub Pages (handled by CI):
#   mkdocs gh-deploy --force

site_name: My Project Docs
site_description: Project documentation
site_url: https://YOUR_ORG.github.io/YOUR_REPO/

repo_name: YOUR_ORG/YOUR_REPO
repo_url: https://github.com/YOUR_ORG/YOUR_REPO

theme:
  name: material
  palette:
    scheme: default
    primary: indigo
    accent: indigo
  features:
    - navigation.tabs
    - navigation.sections
    - navigation.top
    - search.suggest
    - search.highlight
    - content.code.copy

docs_dir: docs

nav:
  - Home: index.md
  - Getting Started: getting-started.md

markdown_extensions:
  - pymdownx.highlight
  - pymdownx.superfences
  - admonition
  - toc:
      permalink: true
