#!/bin/bash
set -e
# =============================================================================
# COMMIT-MSG: Validate commit message
# =============================================================================
# Bloquea mensajes con atribución a IA
# =============================================================================

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Patrones prohibidos en mensaje de commit (case insensitive, grep -iE).
#
# Notas sobre regex:
#   [[:space:]]+  = uno o más espacios (POSIX, portable; cubre "  " doble espacio)
#   [-_[:space:]]? = separador opcional: guión, underscore, espacio o nada
#   \b            = word boundary (GNU grep ext.; ya en uso en la versión previa)
#
# Limitación conocida: no detecta homoglifos Unicode (e.g., Cl𝛂ude). Best-effort.
AI_PATTERNS=(
    # ── Co-authored-by trailer — proveedor en el mismo trailer ─────────
    "co-authored-by:.*\b(claude|anthropic|gpt|chatgpt|openai|copilot|gemini)\b"
    "co-authored-by:.*[[:space:]]ai\b"

    # ── "made/generated/written/created/assisted by/with X" ────────────
    # Acepta cualquier whitespace entre verbo, by/with y proveedor.
    "(made|generated|written|created|assisted|built|developed|authored)[[:space:]]+(by|with)[[:space:]]+(claude|gpt|chatgpt|openai|anthropic|gemini|copilot|ai|llm)"

    # ── "with help from X" ─────────────────────────────────────────────
    "with[[:space:]]+help[[:space:]]+from[[:space:]]+(claude|gpt|chatgpt|openai|anthropic|gemini|copilot|ai|llm)"

    # ── "X-assisted" / "X assisted" / "X_assisted" ─────────────────────
    # Cubre: anthropic-assisted, openai-assisted, ai-assisted, llm assisted, etc.
    "(claude|gpt|chatgpt|openai|anthropic|gemini|copilot|ai|llm)[-_[:space:]]?assisted"

    # ── Tool / IDE branding ────────────────────────────────────────────
    "claude[-_[:space:]]?code"
    "(github|microsoft)[-_[:space:]]+copilot"

    # ── Claude con cualquier separador + variante de modelo ────────────
    # Cubre: "claude opus", "claude-sonnet", "claude_haiku", "Claude3", "claude4.5", "Claude 4.7"
    "claude[-_[:space:]]?(opus|sonnet|haiku|[0-9])"

    # ── GPT con cualquier separador + versión ──────────────────────────
    # Cubre: gpt-4, gpt 3, gpt_5, gpt4.5
    "gpt[-_[:space:]]?[0-9]"

    # ── ChatGPT standalone ─────────────────────────────────────────────
    "chatgpt"

    # ── Email domains de los proveedores ───────────────────────────────
    "@(anthropic|openai)\\.com"
    "noreply@(anthropic|openai)"
)

for pattern in "${AI_PATTERNS[@]}"; do
    if echo "$COMMIT_MSG" | grep -iqE "$pattern"; then
        echo -e ""
        echo -e "${RED}COMMIT BLOCKED: AI Attribution Detected${NC}"
        echo -e ""
        echo -e "${RED}Found in commit message: ${NC}"
        echo -e "${YELLOW}  Pattern: $pattern${NC}"
        echo -e ""
        echo -e "${RED}Your commit message:${NC}"
        echo -e "${YELLOW}$(cat "$COMMIT_MSG_FILE")${NC}"
        echo -e ""
        echo -e "${GREEN}Remove AI attribution. You are the sole author.${NC}"
        echo -e ""
        exit 1
    fi
done

# Mensaje OK
exit 0
